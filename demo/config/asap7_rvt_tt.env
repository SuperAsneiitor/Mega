# Example process/simulator configuration for ASAP7 RVT TT.
#
# This file is sourced by run_megacell_flow.sh. Paths are relative to the
# project root unless absolute paths are used.

TECH_NAME="asap7"
CORNER_NAME="rvt_tt"

STDCELL_VERILOG_DIR="demo/input/asap7sc7p5t/Verilog"
STDCELL_VERILOG_GLOB="*RVT_TT*.v"

STDCELL_LIB_DIR="demo/input/asap7sc7p5t/LIB/NLDM_d"
STDCELL_LIB_GLOB="*RVT_TT*.lib"

SIMULATOR="iverilog"
IVERILOG_BIN="iverilog"
VVP_BIN="vvp"

# For SIMULATOR=vcs:
VCS_BIN="vcs"

# Pre-built cell library (skips Liberty parsing when set):
# CELL_LIB="demo/cell_lib/asap7_rvt_tt.json"

# Used when SIMULATOR=custom. Available placeholders:
# {sources}, {stdcell_sources}, {netlist}, {tb}, {simv}, {work_dir}
COMPILE_CMD_TEMPLATE=""
RUN_CMD_TEMPLATE=""

MAX_VECTORS="1000000"
SIM_DELAY="1"
